EU_COMPLY_ENVIRONMENT=development
EU_COMPLY_API_PREFIX=/api/v1
EU_COMPLY_SECRET_KEY=change-me-in-production
EU_COMPLY_DATABASE_URL=postgresql+asyncpg://eu_comply:eu_comply@localhost:5432/eu_comply
EU_COMPLY_REDIS_URL=redis://localhost:6379/0
EU_COMPLY_ARTIFACT_STORAGE_PATH=.data/artifacts
EU_COMPLY_AUTO_CREATE_SCHEMA=true

EU_COMPLY_BOOTSTRAP_ADMIN_EMAIL=admin@eucomply.dev
EU_COMPLY_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
EU_COMPLY_BOOTSTRAP_API_CLIENT_ID=eu-comply-dev-client
EU_COMPLY_BOOTSTRAP_API_CLIENT_SECRET=eu-comply-dev-secret

EU_COMPLY_LLM_DEFAULT_PROVIDER=ollama
EU_COMPLY_EMBEDDING_DEFAULT_PROVIDER=ollama
EU_COMPLY_OPENROUTER_API_KEY=
EU_COMPLY_OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
EU_COMPLY_OLLAMA_BASE_URL=http://localhost:11434
EU_COMPLY_OLLAMA_DEFAULT_CHAT_MODEL=qwen3:8b
EU_COMPLY_OLLAMA_DEFAULT_EMBEDDING_MODEL=nomic-embed-text

EU_COMPLY_MCP_ENABLED=true
EU_COMPLY_MCP_DEFAULT_ORG_SLUG=default
